@page "/"

@using Messanger.Shared.Module
@using Shared.Interfaces

@inject IMessanger MessageService
@inject NavigationManager Nav

<div class="messenger-container">
    
    <div class="sidebar">
        <div class="sidebar-header">
            <input type="text" class="search-input" placeholder="Поиск..." />
        </div>

        <div class="chat-list">
            @foreach (var chat in chats)
            {
                <div class="chat-item @(selectedChat?.Id == chat.Id ? "active" : "")" 
                     @onclick="() => SelectChat(chat)">
                    
                    <div class="avatar">@chat.Name.FirstOrDefault()</div>
                    <div class="chat-preview">
                        <div class="chat-name">@chat.Name</div>
                        <div class="last-message">Нажми, чтобы посмотреть сообщения</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="chat-area">
        @if (selectedChat != null)
        {
            <div class="chat-header">
                <div class="avatar small">@selectedChat.Name.FirstOrDefault()</div>
                <div class="chat-title">@selectedChat.Name</div>
            </div>

            <div class="messages-container">
                @foreach (var msg in currentMessages)
                {
                    <div class="message @(msg.SenderId == currentUserId ? "outgoing" : "incoming")">
                        <div class="msg-text">@msg.Text</div>
                        <div class="msg-time">@msg.CreatedAt.ToString("HH:mm")</div>
                    </div>
                }
            </div>

            <div class="input-area">
                <input type="text" class="message-input" placeholder="Написать сообщение..." 
                       @bind="newMessageText" @bind:event="oninput" 
                       @onkeyup="HandleKeyUp" />
                <button class="send-btn" @onclick="SendMessage">➤</button>
            </div>
        }
        else
        {
            <div style="display:flex; justify-content:center; align-items:center; height: 100%; color: gray;">
                Выберите чат для начала общения
            </div>
        }
    </div>
</div>

@code {
    private int currentUserId;
    private Chat? selectedChat;
    private List<Message> currentMessages = new();
    private List<Chat> chats = new();
    private string newMessageText = "";

    protected override async Task OnInitializedAsync()
    {
        currentUserId = 1;

        if (currentUserId == 0)
        {
            Nav.NavigateTo("/register");
            return;
        }

        chats = await MessageService.GetAllMessageGroupAsync(currentUserId);

        selectedChat = chats.FirstOrDefault();

        if (selectedChat != null)
        {
            currentMessages = await MessageService.GetChatMessageAsync(selectedChat.Id);
        }
    }

    private async Task SelectChat(Chat chat)
    {
        selectedChat = chat;
        currentMessages = await MessageService.GetChatMessageAsync(selectedChat.Id);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessageText) || selectedChat == null) return;


        var request = new Message
        {
            SenderId = currentUserId,
            ChatId = selectedChat.Id,
            Text = newMessageText,
            CreatedAt = DateTime.Now
        };

        await MessageService.SendMessageAsync(request);

        newMessageText = "";
        currentMessages = await MessageService.GetChatMessageAsync(selectedChat.Id);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }
}